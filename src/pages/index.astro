---
import { Image } from 'astro:assets';
import logo from '../assets/logo.png';
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Hero from '../components/Hero.astro';
import Servicios from '../components/Servicios.astro';
import Galeria from '../components/Galeria.astro';
import Porque from '../components/Porque.astro';
import Resenas from '../components/Resenas.astro';
import WhatsAppButton from '../components/WhatsAppButton.astro';
---

<Layout>
  <Navbar />
  <main>
    <Hero />
    <Servicios />
    <Galeria />
    <Porque />
    <Resenas />
  </main>

  <!-- Footer -->
  <footer class="bg-zinc-900 pt-12 pb-6 text-sm">
    <div class="container mx-auto px-6 max-w-6xl">

      <!-- Fila principal -->
      <div class="flex flex-col md:flex-row md:items-start md:justify-between gap-10 pb-10 border-b border-white/10">

        <!-- Logo + descripción -->
        <div class="flex-1 max-w-xs">
          <Image src={logo} alt="CAMAÑO HIDROGAS" class="h-36 w-auto mb-4 brightness-0 invert" />
          <p class="text-gray-200 text-sm leading-relaxed">
            Instalaciones de gas y plomería en San Martín de los Andes, Neuquén.
            Más de 30 años de experiencia.
          </p>
        </div>

        <!-- Navegación -->
        <div class="mt-8 md:mt-0 md:pt-10">
          <p class="text-yellow-300 font-semibold mb-4 uppercase tracking-widest text-xs">Menú</p>
          <ul class="space-y-2 text-gray-200 text-sm">
            <li><a href="#inicio"    class="hover:text-yellow-200  transition-colors">Inicio</a></li>
            <li><a href="#servicios" class="hover:text-yellow-200 transition-colors">¿Quiénes somos?</a></li>
            <li><a href="#galeria"   class="hover:text-yellow-200  transition-colors">Servicios</a></li>
            <li><a href="#porque"    class="hover:text-yellow-200  transition-colors">¿Por qué nos eligen?</a></li>
            <li><a href="#resenas"   class="hover:text-yellow-200  transition-colors">Reseñas</a></li>
          </ul>
        </div>

        <!-- Contacto + redes -->
        <div class="md:pt-10">
          <p class="text-yellow-300 font-semibold mb-4 uppercase tracking-widest text-xs">Contacto</p>
          <ul class="space-y-3 text-gray-200 text-sm">
            <li class="flex items-center gap-2">
              <svg class="w-4 h-4 shrink-0 text-yellow-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
              San Martín de los Andes, Neuquén
            </li>
            <li>
              <a href="tel:+541132964682" class="flex items-center gap-2 hover:text-yellow-200 transition-colors">
                <svg class="w-4 h-4 shrink-0 text-yellow-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
                Presupuestos +54 11 3296-4682
              </a>
            </li>
            <li>
              <a href="tel:+541132964682" class="flex items-center gap-2 hover:text-yellow-200 transition-colors">
                <svg class="w-4 h-4 shrink-0 text-yellow-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/></svg>
                Emergencias: +54 11 3296-4682
              </a>
            </li>
            <li>
              <a
                href="https://wa.me/541132964682?text=Hola%20Cama%C3%B1o%2C%20los%20contacto%20desde%20su%20p%C3%A1gina%20web."
                target="_blank" rel="noopener noreferrer"
                class="flex items-center gap-2 hover:text-yellow-200 transition-colors"
              >
                <svg class="w-4 h-4 shrink-0 text-yellow-300" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/></svg>
                WhatsApp
              </a>
            </li>
            <li>
              <a
                href="https://www.instagram.com/camanohidrogas.sma?igsh=MTM0ODN1Nnk2NzRyYQ%3D%3D"
                target="_blank" rel="noopener noreferrer"
                class="flex items-center gap-2 hover:text-yellow-200 transition-colors"
              >
                <svg class="w-4 h-4 shrink-0 text-yellow-300" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/></svg>
                @camanohidrogas.sma
              </a>
            </li>
          </ul>
        </div>

      </div>

      <!-- Fila inferior -->
      <div class="flex flex-col sm:flex-row sm:justify-between gap-2 pt-5 text-gray-200 text-xs">
        <p>© {new Date().getFullYear()} CAMAÑO HIDROGAS. Todos los derechos reservados.</p>
      </div>

    </div>
  </footer>

  <WhatsAppButton />
</Layout>
