---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import Servicios from '../components/Servicios.astro';
import Galeria from '../components/Galeria.astro';
import Resenas from '../components/Resenas.astro';
import WhatsAppButton from '../components/WhatsAppButton.astro';
import Navbar from '../components/Navbar.astro';
---

<Layout>
  <Navbar />
  <main>
    <Hero />
    <Servicios />
    <Galeria />
    <Resenas />
  </main>

  <!-- Footer -->
  <footer class="bg-gray-700 py-10 text-center text-sm">
    <div class="container mx-auto px-6">
      <img
        src="/logo.png"
        alt="CAMAÑO HIDROGAS"
        class="h-32 w-auto mx-auto mb-4 brightness-0 invert opacity-90"
        loading="lazy"
      />
      <p class="text-white/60">San Martín de los Andes, Neuquén, Argentina</p>
      <p class="mt-3 text-white/50 text-xs">
        © {new Date().getFullYear()} CAMAÑO HIDROGAS. Todos los derechos reservados.
      </p>
    </div>
  </footer>

  <WhatsAppButton />
</Layout>
