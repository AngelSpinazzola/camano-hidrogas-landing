---
const links = [
  { href: '#inicio',    label: 'Inicio'             },
  { href: '#servicios', label: '¿Quiénes somos?'   },
  { href: '#galeria',   label: 'Servicios'           },
  { href: '#porque',    label: '¿Por qué nos eligen?' },
  { href: '#resenas',   label: 'Reseñas'            },
];

const whatsappUrl = `https://wa.me/541132964682?text=${encodeURIComponent('Hola Camaño, los contacto desde su página web. Quisiera consultar por un servicio.')}`;
---

<header id="navbar" class="fixed top-0 inset-x-0 z-40 transition-all duration-300">
  <div class="container mx-auto px-6 max-w-6xl">
    <div class="flex justify-end items-center h-16 sm:h-20 md:grid md:grid-cols-[1fr_auto_1fr]">
      <!-- Spacer izquierdo -->
      <div></div>

      <!-- Links desktop — centrados -->
      <nav class="hidden md:flex items-center gap-20" aria-label="Navegación principal">
        {links.map(l => (
          <a
            href={l.href}
            class="nav-link text-base font-semibold text-white hover:text-yellow-200 transition-colors duration-200"
          >
            {l.label}
          </a>
        ))}
      </nav>

      <!-- Hamburger — alineado a la derecha en mobile -->
      <div class="flex justify-end">
        <button
          id="menu-toggle"
          class="md:hidden p-2 text-white transition-colors duration-200"
          aria-label="Abrir menú"
          aria-expanded="false"
        >
          <svg class="w-7 h-7" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" viewBox="0 0 24 24">
            <path d="M4 6h16M4 12h16M4 18h16"/>
          </svg>
        </button>
      </div>

    </div>
  </div>

  <!-- Mobile menu full-screen -->
  <div id="mobile-menu" class="fixed inset-0 z-50 bg-slate-900 flex flex-col opacity-0 pointer-events-none transition-opacity duration-300 md:hidden">

    <!-- Botón cerrar -->
    <button id="menu-close" class="absolute top-[13px] right-6 w-10 h-10 flex items-center justify-center rounded-full bg-white/10 hover:bg-white/20 text-white transition-colors" aria-label="Cerrar menú">
      <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" viewBox="0 0 24 24">
        <path d="M6 18L18 6M6 6l12 12"/>
      </svg>
    </button>

    <!-- Links -->
    <nav class="flex flex-col px-8 pt-20 flex-1">
      {links.map((l, i) => (
        <a
          href={l.href}
          class="mobile-link py-4 text-gray-200 font-semibold text-lg uppercase tracking-widest border-b border-white/10 last:border-0 hover:text-yellow-200 transition-colors duration-200 opacity-0 -translate-x-4"
          style={`transition-delay:${i * 60}ms`}
        >
          {l.label}
        </a>
      ))}

      <!-- Íconos redes -->
      <div class="mt-8 flex items-center gap-5 mobile-link opacity-0 -translate-x-4" style={`transition-delay:${links.length * 60}ms`}>
        <a href="https://www.instagram.com/camanohidrogas.sma?igsh=MTM0ODN1Nnk2NzRyYQ%3D%3D" target="_blank" rel="noopener noreferrer" class="text-white hover:text-white transition-colors" aria-label="Instagram">
          <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/></svg>
        </a>
        <a href={whatsappUrl} target="_blank" rel="noopener noreferrer" class="text-white hover:text-white transition-colors" aria-label="WhatsApp">
          <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/></svg>
        </a>
      </div>

      <!-- Logo -->
      <div class="mt-8 mobile-link opacity-0 -translate-x-4" style={`transition-delay:${(links.length + 1) * 60}ms`}>
        <img src="/logo.png" alt="CAMAÑO HIDROGAS" class="h-24 w-auto brightness-0 invert" />
      </div>
    </nav>

  </div>
</header>

<style>
  /* Subrayado que se expande desde el centro */
  .nav-link {
    position: relative;
    padding-bottom: 3px;
  }
  .nav-link::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 50%;
    width: 0;
    height: 2px;
    background: currentColor;
    transition: width 0.3s ease, left 0.3s ease;
  }
  .nav-link:hover::after {
    width: 100%;
    left: 0;
  }
  .mobile-link {
    transition: opacity 0.4s ease, transform 0.4s ease, color 0.2s ease;
    transition-delay: var(--i, 0);
  }
</style>

<script>
  const navbar     = document.getElementById('navbar')!;
  const navLinks   = document.querySelectorAll<HTMLElement>('.nav-link');
  const toggle     = document.getElementById('menu-toggle')!;
  const mobileMenu = document.getElementById('mobile-menu')!;
  // ── Scroll: transparente → blanco ────────────────────
  function applyScroll(scrolled: boolean) {
    if (scrolled) {
      navbar.classList.add('bg-white', 'shadow-md');
      navLinks.forEach(l => {
        l.classList.replace('text-white', 'text-gray-700');
        l.classList.replace('hover:text-yellow-200', 'hover:text-cyan-800');
      });
      toggle.classList.replace('text-white', 'text-gray-700');
    } else {
      navbar.classList.remove('bg-white', 'shadow-md');
      navLinks.forEach(l => {
        l.classList.replace('text-gray-700', 'text-white');
        l.classList.replace('hover:text-cyan-800', 'hover:text-yellow-200');
      });
      toggle.classList.replace('text-gray-700', 'text-white');
    }
  }

  window.addEventListener('scroll', () => applyScroll(window.scrollY > 60), { passive: true });
  applyScroll(window.scrollY > 60);

  // ── Full-screen menu ──────────────────────────────────
  const mobileLinks = document.querySelectorAll<HTMLElement>('.mobile-link');

  function openMenu() {
    mobileMenu.classList.remove('opacity-0', 'pointer-events-none');
    mobileMenu.classList.add('opacity-100');
    document.body.style.overflow = 'hidden';
    toggle.setAttribute('aria-expanded', 'true');
    mobileLinks.forEach(l => {
      l.classList.remove('opacity-0', '-translate-x-4');
      l.classList.add('opacity-100', 'translate-x-0');
    });
  }

  function closeMenu() {
    mobileLinks.forEach(l => {
      l.classList.add('opacity-0', '-translate-x-4');
      l.classList.remove('opacity-100', 'translate-x-0');
    });
    mobileMenu.classList.add('opacity-0', 'pointer-events-none');
    mobileMenu.classList.remove('opacity-100');
    document.body.style.overflow = '';
    toggle.setAttribute('aria-expanded', 'false');
  }

  toggle.addEventListener('click', () => {
    const isOpen = !mobileMenu.classList.contains('pointer-events-none');
    isOpen ? closeMenu() : openMenu();
  });

  document.getElementById('menu-close')!.addEventListener('click', closeMenu);
  document.querySelectorAll('.mobile-link').forEach(l => l.addEventListener('click', closeMenu));
</script>
