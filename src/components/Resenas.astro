---
const resenas = [
  {
    nombre: 'María G.',
    fecha: 'Febrero 2025',
    estrellas: 5,
    texto: 'Excelente trabajo. Vinieron rápido cuando tuve una pérdida de gas y lo solucionaron en el momento. Muy profesionales y limpios.',
  },
  {
    nombre: 'Carlos T.',
    fecha: 'Enero 2025',
    estrellas: 5,
    texto: 'Hice la instalación de gas completa para mi casa nueva con Camaño. Todo perfecto, en tiempo y forma. Lo recomiendo sin dudas.',
  },
  {
    nombre: 'Laura P.',
    fecha: 'Diciembre 2024',
    estrellas: 5,
    texto: 'Muy buen servicio de destapación. Puntual, amable y resolvió todo enseguida. Ya los tengo guardados para la próxima.',
  },
  {
    nombre: 'Sebastián M.',
    fecha: 'Noviembre 2024',
    estrellas: 5,
    texto: 'Profesionales de verdad. Me arreglaron el termotanque el mismo día que los llamé. Precio justo y trabajo impecable.',
  },
  {
    nombre: 'Ana R.',
    fecha: 'Octubre 2024',
    estrellas: 5,
    texto: 'Los recomiendo 100%. Hicieron toda la instalación sanitaria del baño nuevo. Trabajo prolijo y garantizado.',
  },
  {
    nombre: 'Rodrigo F.',
    fecha: 'Septiembre 2024',
    estrellas: 5,
    texto: 'Rápidos, confiables y con precio razonable. Ya los llamé dos veces y siempre quedé conforme. Son los mejores plomeros de la zona.',
  },
];
---

<section id="resenas" class="py-20 bg-gray-50 overflow-hidden">
  <div class="container mx-auto px-6 max-w-6xl">
    <!-- Encabezado -->
    <div class="text-center mb-12">
      <span class="text-gray-950 font-semibold text-xl uppercase tracking-widest">Reseñas</span>
      <h2 class="text-3xl sm:text-4xl font-extrabold text-gray-900 mt-2 mb-2">
        Lo que dicen nuestros clientes
      </h2>
      <div class="flex items-center justify-center gap-2 mt-3">
        <span class="text-yellow-400 text-2xl" aria-hidden="true">★★★★★</span>
        <span class="font-bold text-gray-800 text-lg">5.0</span>
        <span class="text-gray-400 text-sm">· Google Reviews</span>
      </div>
    </div>
  </div>

  <!-- Carrusel infinito -->
  <div class="relative overflow-hidden">
    <!-- Fade izquierda -->
    <div class="absolute left-0 top-0 bottom-0 w-16 bg-gradient-to-r from-gray-50 to-transparent z-10 pointer-events-none"></div>
    <!-- Fade derecha -->
    <div class="absolute right-0 top-0 bottom-0 w-16 bg-gradient-to-l from-gray-50 to-transparent z-10 pointer-events-none"></div>

    <div class="flex gap-6 carousel-track">
      {[...resenas, ...resenas].map((r, i) => (
        <div
          class="flex-shrink-0 w-80 bg-white rounded-2xl p-6 border border-gray-100 shadow-sm"
          aria-hidden={i >= resenas.length ? 'true' : 'false'}
        >
          <!-- Estrellas -->
          <p class="text-yellow-400 text-lg mb-3" aria-label={`${r.estrellas} estrellas`}>
            {'★'.repeat(r.estrellas)}
          </p>

          <!-- Texto -->
          <p class="text-gray-700 text-sm leading-relaxed mb-4 italic">
            "{r.texto}"
          </p>

          <!-- Autor -->
          <div class="flex items-center gap-3 pt-3 border-t border-gray-100">
            <div class="w-9 h-9 rounded-full bg-cyan-50 flex items-center justify-center text-cyan-800 font-bold text-sm" aria-hidden="true">
              {r.nombre.charAt(0)}
            </div>
            <div>
              <p class="font-semibold text-gray-800 text-sm">{r.nombre}</p>
              <p class="text-gray-400 text-xs">{r.fecha}</p>
            </div>
            <svg class="ml-auto w-5 h-5 shrink-0" viewBox="0 0 24 24" aria-label="Google" role="img">
              <path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"/>
              <path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/>
              <path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"/>
              <path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/>
            </svg>
          </div>
        </div>
      ))}
    </div>
  </div>

</section>

<style>
  .carousel-track {
    animation: scroll 30s linear infinite;
    width: max-content;
  }

  .carousel-track:hover {
    animation-play-state: paused;
  }

  @keyframes scroll {
    0%   { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }
</style>
