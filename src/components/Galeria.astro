---
const fotos = [
  {
    src: '/images/plomeria-canieria-neuquen.jpeg',
    alt: 'Trabajo de plomería y cañería en Neuquén — CAMAÑO HIDROGAS',
  },
  {
    src: '/images/trabajos-gas-hidrogas-camano.jpeg',
    alt: 'Trabajos de gas e hidrogas — CAMAÑO HIDROGAS',
  },
  {
    src: '/images/reparacion-plomeria-neuquen.jpeg',
    alt: 'Reparación de plomería en Neuquén — CAMAÑO HIDROGAS',
  },
  {
    src: '/images/obra-gas-camano-hidrogas.jpeg',
    alt: 'Obra de gas — CAMAÑO HIDROGAS San Martín de los Andes',
  },
  {
    src: '/images/destapacion-plomero-san-martin-andes.jpeg',
    alt: 'Destapación de cañería en San Martín de los Andes — CAMAÑO HIDROGAS',
  },
  {
    src: '/images/servicio-plomeria-hidrogas-neuquen.jpeg',
    alt: 'Servicio de plomería e hidrogas en Neuquén — CAMAÑO HIDROGAS',
  },
];

// Reemplazar con IDs reales de videos de YouTube del cliente
const videos = [
  {
    youtubeId: 'MUUrW7xJSw4', // placeholder — reemplazar
    title: 'Instalación de gas completa en vivienda, San Martín de los Andes',
  },
];
---

<section id="galeria" class="py-20 bg-gray-50">
  <div class="container mx-auto px-6 max-w-6xl">
    <!-- Encabezado -->
    <div class="text-center mb-14">
      <span class="text-cyan-800 font-semibold text-xl uppercase tracking-widest">Trabajos realizados</span>
      <h2 class="text-3xl sm:text-4xl font-extrabold text-gray-900 mt-2 mb-4">
        Cada proyecto, una solución a medida
      </h2>
      <p class="text-gray-500 max-w-xl mx-auto">
        Una muestra de lo que hacemos todos los días. Instalaciones, reparaciones y obras realizadas con dedicación y garantía.
      </p>
    </div>

    <!-- Galería de fotos -->
    <div class="grid grid-cols-2 sm:grid-cols-3 gap-3 sm:gap-4 mb-14">
      {fotos.map((foto) => (
        <div class="aspect-square overflow-hidden rounded-2xl bg-gray-200 group cursor-pointer">
          <img
            src={foto.src}
            alt={foto.alt}
            class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
            loading="lazy"
            decoding="async"
          />
        </div>
      ))}
    </div>

    <!-- Videos de YouTube -->
    {videos.length > 0 && (
      <div>
        <h3 class="text-xl font-bold text-gray-800 mb-6 text-center">Videos</h3>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
          {videos.map((video) => (
            <div class="rounded-2xl overflow-hidden shadow-md aspect-video bg-gray-900">
              <iframe
                src={`https://www.youtube.com/embed/${video.youtubeId}`}
                title={video.title}
                class="w-full h-full"
                loading="lazy"
                allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                allowfullscreen
              />
            </div>
          ))}
        </div>
      </div>
    )}
  </div>
</section>
