---
const items = [
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" /></svg>`,
    title: "Respuesta rápida",
    desc: "Atendemos urgencias en el día. Un problema de gas o agua no puede esperar, y lo sabemos.",
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" /><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1 1 15 0Z" /></svg>`,
    title: "30 años en la zona",
    desc: "Conocemos cada barrio de San Martín de los Andes. Somos parte de la comunidad desde hace décadas.",
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" /></svg>`,
    title: "Trabajo garantizado",
    desc: "Presupuesto sin cargo y garantía en materiales y mano de obra. Si algo no queda bien, volvemos sin costo.",
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 5.25a3 3 0 0 1 3 3m3 0a6 6 0 0 1-7.029 5.912c-.563-.097-1.159.026-1.563.43L10.5 17.25H8.25v2.25H6v2.25H2.25v-2.818c0-.597.237-1.17.659-1.591l6.499-6.499c.404-.404.527-1 .43-1.563A6 6 0 0 1 21.75 8.25Z" /></svg>`,
    title: "Gasistas matriculados",
    desc: "Contamos con habilitaciones vigentes. Cada instalación de gas cumple con las normas de seguridad exigidas.",
  },
];
---

<section id="porque" class="py-24 bg-gray-50 overflow-hidden">
  <div class="container mx-auto px-6 max-w-6xl">

    <!-- Todo el contenido entra desde la derecha -->
    <div class="porque-block">

    <div class="mb-12">
      <h2 class="text-3xl sm:text-4xl font-extrabold text-gray-900 leading-tight mb-4">
        ¿Por qué nos <span class="text-cyan-800">eligen?</span>
      </h2>
      <div class="w-12 h-1 bg-cyan-800 rounded-full"></div>
    </div>

    <!-- Layout dos columnas -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">

      <!-- Imagen izquierda -->
      <div class="porque-img rounded-2xl overflow-hidden shadow-xl aspect-[4/3] lg:aspect-auto lg:h-[480px]">
        <img
          src="/images/manos-estrechadas.webp"
          alt="Equipo CAMAÑO HIDROGAS"
          class="w-full h-full object-cover"
          loading="lazy"
          decoding="async"
        />
      </div>

      <!-- Items derecha -->
      <div class="flex flex-col gap-4">
        <p class="text-gray-600 text-lg leading-relaxed mb-4 border-l-4 border-cyan-800 pl-4">
          Más de tres décadas resolviendo problemas reales con profesionalismo y sin dependencias externas.
        </p>
        {items.map((item) => (
          <div
            class="porque-item flex items-start gap-4 bg-white rounded-2xl border border-gray-100 p-5 shadow-sm"
          >
            <div class="w-11 h-11 rounded-full bg-cyan-800 text-white flex items-center justify-center shrink-0">
              <div class="w-5 h-5" set:html={item.icon} />
            </div>
            <div>
              <h3 class="font-bold text-gray-900 text-base mb-0.5">{item.title}</h3>
              <p class="text-gray-500 text-sm leading-relaxed">{item.desc}</p>
            </div>
          </div>
        ))}
      </div>

    </div>
    </div><!-- fin porque-block -->
  </div>
</section>

<style>
  .porque-block {
    opacity: 0;
    transform: translateX(100vw);
    transition: opacity 2s ease, transform 2s cubic-bezier(0.22, 1, 0.36, 1);
  }
  .porque-block.visible {
    opacity: 1;
    transform: translateX(0);
  }
  .porque-item:hover {
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.08);
  }
</style>

<script>
  const section = document.getElementById("porque")!;
  const block = document.querySelector<HTMLElement>(".porque-block")!;
  const obs = new IntersectionObserver(
    (entries) => {
      if (entries[0].isIntersecting) {
        block.classList.add("visible");
        obs.disconnect();
      }
    },
    { threshold: 0.1 }
  );
  obs.observe(section);
</script>
