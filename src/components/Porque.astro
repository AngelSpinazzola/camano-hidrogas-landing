---
const items = [
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" /></svg>`,
    title: 'Respuesta rápida',
    desc: 'Atendemos urgencias en el día. Un problema de gas o agua no puede esperar, y lo sabemos.',
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" /><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1 1 15 0Z" /></svg>`,
    title: '30 años en la zona',
    desc: 'Conocemos cada barrio de San Martín de los Andes. Somos parte de la comunidad desde hace décadas.',
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M11.48 3.499a.562.562 0 0 1 1.04 0l2.125 5.111a.563.563 0 0 0 .475.345l5.518.442c.499.04.701.663.321.988l-4.204 3.602a.563.563 0 0 0-.182.557l1.285 5.385a.562.562 0 0 1-.84.61l-4.725-2.885a.562.562 0 0 0-.586 0L6.982 20.54a.562.562 0 0 1-.84-.61l1.285-5.386a.562.562 0 0 0-.182-.557l-4.204-3.602a.562.562 0 0 1 .321-.988l5.518-.442a.563.563 0 0 0 .475-.345L11.48 3.5Z" /></svg>`,
    title: 'Trabajo garantizado',
    desc: 'Presupuesto sin cargo y garantía en materiales y mano de obra. Si algo no queda bien, volvemos sin costo.',
  },
];
---

<section id="porque" class="py-24 bg-gray-50">
  <div class="container mx-auto px-6 max-w-6xl">

    <!-- Encabezado -->
    <div class="text-center mb-14">
      <span class="text-cyan-800 text-sm font-semibold uppercase tracking-widest">Nuestros diferenciales</span>
      <h2 class="text-3xl sm:text-4xl font-extrabold text-gray-900 mt-2 mb-4">
        ¿Por qué nos eligen?
      </h2>
      <p class="text-gray-500 text-lg max-w-xl mx-auto leading-relaxed">
        Más de tres décadas resolviendo problemas reales con profesionalismo y sin dependencias externas.
      </p>
    </div>

    <!-- Cards -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {items.map((item, i) => (
        <div
          class="porque-card bg-white rounded-2xl border border-gray-100 p-7 flex flex-col gap-4 shadow-sm hover:shadow-lg hover:-translate-y-1 transition-all duration-300"
          data-dir={i === 0 ? 'left' : i === 2 ? 'right' : 'up'}
          style={`--delay:${Math.floor(i / 3) * 120}ms`}
        >
          <div class="w-12 h-12 rounded-xl bg-cyan-50 text-cyan-800 flex items-center justify-center shrink-0">
            <div class="w-6 h-6" set:html={item.icon} />
          </div>
          <div>
            <h3 class="font-bold text-gray-900 text-base mb-1">{item.title}</h3>
            <p class="text-gray-500 text-sm leading-relaxed">{item.desc}</p>
          </div>
        </div>
      ))}
    </div>

  </div>
</section>

<style>
  .porque-card {
    opacity: 0;
    transition:
      opacity 0.6s ease var(--delay, 0ms),
      transform 0.6s cubic-bezier(0.22, 1, 0.36, 1) var(--delay, 0ms),
      box-shadow 0.3s ease;
  }
  .porque-card[data-dir="left"]  { transform: translateX(-60px); }
  .porque-card[data-dir="right"] { transform: translateX(60px);  }
  .porque-card[data-dir="up"]    { transform: translateY(40px);  }

  .porque-card.visible {
    opacity: 1;
    transform: translate(0, 0);
  }
</style>

<script>
  const cards = document.querySelectorAll<HTMLElement>('.porque-card');
  const obs = new IntersectionObserver(entries => {
    entries.forEach(e => {
      if (e.isIntersecting) {
        (e.target as HTMLElement).classList.add('visible');
        obs.unobserve(e.target);
      }
    });
  }, { threshold: 0.1 });
  cards.forEach(c => obs.observe(c));
</script>
