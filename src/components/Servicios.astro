---
const servicios = [
  {
    title: "Instalación de Gas",
    desc: "Instalaciones y ampliaciones de gas natural y envasado. Habilitaciones y certificaciones.",
    bg: "/images/gas.jpg"
  },
  {
    title: "Plomería General",
    desc: "Reparación y montaje de cañerías, sanitarios, griferías y todo tipo de instalaciones sanitarias.",
    bg: "/images/plomeria.jpg"
  },
  {
    title: "Destapaciones",
    desc: "Destapado de cañerías, piletas, inodoros y desagües con equipamiento profesional.",
    bg: "/images/destapaciones.jpg"
  },
  {
    title: "Reparaciones Urgentes",
    desc: "Atención rápida para pérdidas de agua y gas, roturas y emergencias en el hogar o comercio.",
    bg: "images/emergencia.jpg"
  },
  {
    title: "Gasistas Matriculados",
    desc: "Habilitados para emitir certificados de instalaciones de gas requeridos por el municipio.",
    bg: "images/gasista-matriculado.jpeg"
  },
  {
    title: "Termotanques y Calefones",
    desc: "Instalación, mantenimiento y reparación de termotanques, calefones y calefacción central.",
    bg: "/images/termotanque.jpg"
  },
];
---

<section id="servicios" class="bg-white pt-6 pb-20">
  <div class="container mx-auto max-w-6xl px-6">
    <!-- Encabezado editorial -->
    <div class="relative mb-14 overflow-hidden py-14">

      <!-- Contenido -->
      <div class="relative flex flex-col gap-8 lg:flex-row lg:items-end lg:justify-between">

        <!-- Izquierda: eyebrow + título -->
        <div class="max-w-xl">
          <div class="mb-4 flex items-center gap-3">
            <span class="h-6 w-1.5 rounded-full bg-yellow-300"></span>
            <span class="text-lg font-semibold uppercase tracking-[0.2em] text-gray-950">Quiénes somos</span>
          </div>
          <h2 class="text-4xl font-extrabold leading-tight text-gray-900 sm:text-5xl">
            Gas y plomería<br />
            <span class="text-yellow-300">en San Martín de los Andes.</span>
          </h2>
        </div>

        <!-- Derecha: descripción con borde izquierdo + 30 decorativo -->
        <div class="relative max-w-sm">
          <p class="relative border-l-4 border-yellow-300 pl-5 text-base leading-relaxed text-gray-500">
            Somos una empresa con más de 30 años de experiencia en plomería y gas en la región del Neuquén. <span class="font-semibold text-gray-900">Trabajamos con responsabilidad, puntualidad y garantía en cada obra.</span>
          </p>
        </div>

      </div>
    </div>

    <!-- Grid de servicios -->
    <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {
        servicios.map((s) => (
          <div
            class="group relative overflow-hidden rounded-lg border border-gray-100 bg-white p-6 transition-all duration-300 hover:shadow-lg hover:shadow-cyan-400/10"
            style={s.bg ? `background-image: url(${s.bg}); background-size: cover; background-position: center;` : ''}
          >
            {s.bg && <div class="absolute inset-0 bg-slate-900/70 transition-opacity duration-300 group-hover:bg-slate-900/60" />}
            <div class="relative z-10 flex flex-col justify-between h-full min-h-[140px]">
              <h3 class={`text-lg font-bold transition-colors ${s.bg ? 'text-white' : 'text-gray-900 group-hover:text-cyan-800'}`}>
                {s.title}
              </h3>
              <p class={`mt-auto pt-16 text-sm leading-relaxed ${s.bg ? 'text-gray-100' : 'text-gray-500'}`}>{s.desc}</p>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>
