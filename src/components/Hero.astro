---
import { Image } from 'astro:assets';
import logo from '../assets/logo.png';
const whatsappNumber = "5492972509718";
const whatsappMsg = encodeURIComponent(
  "Hola Camaño, los contacto desde su página web. Quisiera consultar por un servicio.",
);
const whatsappUrl = `https://wa.me/${whatsappNumber}?text=${whatsappMsg}`;
---

<section
  id="inicio"
  class="relative flex min-h-[480px] items-center overflow-hidden lg:min-h-[80vh]"
>
  <!-- Carrusel de fondo -->
  <Image
    src="/images/fondo-hero.png"
    alt=""
    width={1920}
    height={1080}
    aria-hidden="true"
    class="hero-bg absolute inset-0 h-full w-full object-cover object-center opacity-100 transition-opacity duration-1000"
    loading="eager"
    fetchpriority="high"
  />
  <Image
    src="/images/gas-instalacion-4.jpeg"
    alt=""
    width={1920}
    height={1080}
    aria-hidden="true"
    class="hero-bg absolute inset-0 h-full w-full object-cover object-center opacity-0 transition-opacity duration-1000"
    loading="eager"
  />
  <Image
    src="/images/plomeria-instalacion-2.jpeg"
    alt=""
    width={1920}
    height={1080}
    aria-hidden="true"
    class="hero-bg absolute inset-0 h-full w-full object-cover object-center opacity-0 transition-opacity duration-1000"
    loading="eager"
  />

  <!-- Overlay: oscuro a la izquierda, se desvanece hacia la derecha -->
  <div
    class="absolute inset-0 bg-gradient-to-r from-slate-900/95 via-slate-900/75 to-slate-900/20"
  >
  </div>
  <!-- Capa extra para mobile (imagen muy expuesta en pantallas angostas) -->
  <div class="absolute inset-0 bg-slate-900/40 sm:hidden"></div>

  <!-- Contenido -->
  <div class="relative z-10 w-full px-6 pb-10 pt-20 lg:pb-24 lg:pt-24">
    <div class="mx-auto max-w-7xl lg:pl-10 xl:pl-16">
    <div class="flex flex-col items-center gap-12 lg:flex-row">
      <!-- Columna izquierda: texto -->
      <div class="max-w-3xl flex-1">
        <!-- Logo mobile -->
        <div class="logo-wrap mb-4 flex justify-center lg:hidden">
          <Image
            src={logo}
            alt="CAMAÑO HIDROGAS"
            class="w-36 brightness-0 invert"
            loading="eager"
          />
        </div>

        <!-- Etiqueta -->
        <p
          class="mb-3 text-sm font-semibold uppercase tracking-widest text-yellow-300"
        >
          San Martín de los Andes, Neuquén
        </p>

        <!-- Titular -->
        <h1
          class="mb-5 text-4xl font-extrabold leading-tight text-white sm:text-5xl lg:text-6xl"
        >
          Soluciones integrales en <span class="text-yellow-300"
            >gas y plomería.</span
          >
        </h1>

        <!-- Descripción -->
        <p class="mb-8 text-lg leading-relaxed text-gray-100">
          Más de 30 años resolviendo instalaciones de gas, plomería y
          destapaciones en la región con profesionalismo y garantía.
          <span class="font-semibold text-yellow-300">
            Cotizaciones sin cargo.</span
          >
        </p>

        <!-- CTAs -->
        <div class="flex flex-col gap-3 sm:flex-row">
          <a
            href="#servicios"
            class="inline-flex items-center justify-center gap-2 rounded-xl border border-white/30 px-7 py-3.5 text-base font-medium text-white transition-all duration-200 hover:border-white hover:bg-white/10"
          >
            Ver servicios
            <svg
              class="h-4 w-4"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
              aria-hidden="true"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M19 9l-7 7-7-7"></path>
            </svg>
          </a>

          <a
            href={whatsappUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center justify-center gap-3 rounded-xl bg-green-500 px-7 py-3.5 text-base font-semibold text-white shadow-lg shadow-black/20 transition-all duration-200 hover:scale-105 hover:bg-green-400"
            aria-label="Contactar por WhatsApp"
          >
            <svg
              class="h-5 w-5 shrink-0"
              fill="currentColor"
              viewBox="0 0 24 24"
              aria-hidden="true"
            >
              <path
                d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"
              ></path>
            </svg>
            Consultar por WhatsApp
          </a>
        </div>

        <!-- Indicadores -->
        <div
          id="hero-stats"
          class="mt-8 grid grid-cols-3 gap-4 border-t border-white/20 pt-6"
        >
          <div>
            <p
              class="text-3xl font-bold text-yellow-300"
              data-countup
              data-target="30"
              data-prefix="+"
            >
              +30
            </p>
            <p class="mt-0.5 text-xs text-white">Años de experiencia</p>
          </div>
          <div class="border-x border-white/20 px-4">
            <p
              class="text-3xl font-bold text-yellow-300"
              data-countup
              data-target="800"
              data-prefix="+"
            >
              +800
            </p>
            <p class="mt-0.5 text-xs text-white">Trabajos realizados</p>
          </div>
          <div>
            <p
              class="text-3xl font-bold text-yellow-300"
              data-countup
              data-target="24"
              data-suffix="hs"
            >
              24hs
            </p>
            <p class="mt-0.5 text-xs text-white">Respuesta rápida</p>
          </div>
        </div>
      </div>

      <!-- Columna derecha: logo desktop -->
      <div class="hidden flex-1 items-center justify-center lg:flex">
        <div class="logo-wrap">
          <Image
            src={logo}
            alt="CAMAÑO HIDROGAS"
            class="w-64 brightness-0 drop-shadow-2xl invert xl:w-80"
            loading="eager"
          />
        </div>
      </div>
    </div>
    </div>
  </div>
</section>

<style>
  /* Ken Burns: zoom lento mientras el slide está activo */
  @keyframes kenBurns {
    from {
      transform: scale(1);
    }
    to {
      transform: scale(1.08);
    }
  }
  .hero-bg.kb-active {
    animation: kenBurns 4s ease-out forwards;
  }

  @keyframes logoCoalesce {
    0% {
      opacity: 0;
      transform: scale(1.6);
      filter: blur(40px);
    }
    40% {
      opacity: 1;
      transform: scale(1.04);
      filter: blur(5px);
    }
    65% {
      transform: scale(0.97);
      filter: blur(1px);
    }
    82% {
      transform: scale(1.01);
      filter: blur(0);
    }
    100% {
      opacity: 1;
      transform: scale(1);
      filter: blur(0);
    }
  }
  @keyframes logoFloat {
    0%,
    100% {
      transform: translateY(0px);
    }
    50% {
      transform: translateY(-10px);
    }
  }
  .logo-wrap {
    opacity: 0;
    animation:
      logoCoalesce 1.2s cubic-bezier(0.22, 1, 0.36, 1) 0.15s forwards,
      logoFloat 4s ease-in-out 1.4s infinite;
  }
</style>

<script>
  // ── Carrusel de fondo ────────────────────────────────
  const bgSlides = document.querySelectorAll<HTMLElement>(".hero-bg");
  let bgCurrent = 0;
  setInterval(() => {
    bgSlides[bgCurrent].classList.replace("opacity-100", "opacity-0");
    bgCurrent = (bgCurrent + 1) % bgSlides.length;
    bgSlides[bgCurrent].classList.replace("opacity-0", "opacity-100");
  }, 3000);

  // ── Contadores ───────────────────────────────────────
  const counters = document.querySelectorAll<HTMLElement>("[data-countup]");
  const DURATION = 3500;

  counters.forEach((el) => {
    const prefix = el.dataset.prefix ?? "";
    const suffix = el.dataset.suffix ?? "";
    el.textContent = prefix + "0" + suffix;
  });

  function easeOut(t: number) {
    return 1 - Math.pow(1 - t, 3);
  }

  function animateCounter(el: HTMLElement) {
    const target = parseInt(el.dataset.target!);
    const prefix = el.dataset.prefix ?? "";
    const suffix = el.dataset.suffix ?? "";
    const start = performance.now();
    function tick(now: number) {
      const progress = Math.min((now - start) / DURATION, 1);
      el.textContent = prefix + Math.round(easeOut(progress) * target) + suffix;
      if (progress < 1) requestAnimationFrame(tick);
    }
    requestAnimationFrame(tick);
  }

  const statsEl = document.getElementById("hero-stats");
  if (statsEl) {
    const obs = new IntersectionObserver(
      (entries) => {
        if (entries[0].isIntersecting) {
          counters.forEach(animateCounter);
          obs.disconnect();
        }
      },
      { threshold: 0.6 },
    );
    obs.observe(statsEl);
  }
</script>
